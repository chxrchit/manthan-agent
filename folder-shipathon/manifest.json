{
  "manifest_version": 3,
  "name": "Gmail AI Draft Agent",
  "version": "1.0.0",
  "description": "Reads your emails and drafts smart replies using your AI pipeline.",

  "permissions": [
    "activeTab",
    "storage",
    "identity"
  ],

  "host_permissions": [
    "https://mail.google.com/*",
    "https://gmail.googleapis.com/*"
  ],

  "oauth2": {
    "client_id": "472120308708-f1tq0p5mqa18q4l6jf3ev66gnpo6omrj.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/gmail.compose"
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
